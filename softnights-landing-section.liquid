{% comment %}
  SoftNights Sleep Solutions — Complete High-Converting Shopify Liquid Section
  Custom built with Tailwind CSS, interactive Sleep Assessment Quiz, FAQs, and Testimonials.
  
  HOW TO USE:
  1. In your Shopify Theme editor, go to Edit Code -> Sections -> Add a new section called "softnights-landing".
  2. Paste the entire content of this file inside it.
  3. Customize all text, colors, images, and prices directly in the Shopify Theme Customizer!
  4. Ensure you enter your Shopify Product Variant ID in the Section Settings to enable instant checkout.
{% endcomment %}

<!-- Tailwind CSS and Fonts CDN (Optional toggle in settings) -->
{% if section.settings.enable_tailwind_cdn %}
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,600;0,700;1,400&family=JetBrains+Mono:wght@400;500&display=swap');
    
    .softnights-container {
      font-family: 'Inter', sans-serif;
    }
    .softnights-font-serif {
      font-family: 'Playfair Display', serif;
    }
    .softnights-font-mono {
      font-family: 'JetBrains Mono', monospace;
    }
  </style>
{% endif %}

<style>
  :root {
    --color-sage: {{ section.settings.color_sage }};
    --color-sage-light: {{ section.settings.color_sage_light }};
    --color-cream: {{ section.settings.color_cream }};
    --color-charcoal: {{ section.settings.color_charcoal }};
    --color-gold: {{ section.settings.color_gold }};
    --color-blush: {{ section.settings.color_blush }};
    --color-warm-grey: {{ section.settings.color_warm_grey }};
  }

  .bg-sage-custom { background-color: var(--color-sage); }
  .text-sage-custom { color: var(--color-sage); }
  .border-sage-custom { border-color: var(--color-sage); }
  
  .bg-cream-custom { background-color: var(--color-cream); }
  .text-charcoal-custom { color: var(--color-charcoal); }
  .border-cream-custom { border-color: var(--color-cream); }
  
  .bg-gold-custom { background-color: var(--color-gold); }
  .text-gold-custom { color: var(--color-gold); }
  
  .bg-blush-custom { background-color: var(--color-blush); }
  .text-blush-custom { color: var(--color-blush); }

  .hover-scale-subtle:hover {
    transform: scale(1.01);
  }
</style>

<div class="softnights-container bg-cream-custom text-charcoal-custom antialiased selection:bg-sage-custom/20 selection:text-charcoal-custom overflow-x-hidden">
  
  <!-- 1. TOP BANNER REASSURANCE -->
  {% if section.settings.show_top_banner %}
    <div class="bg-sage-custom text-white text-[11px] font-semibold text-center py-2 px-4 uppercase tracking-widest flex items-center justify-center gap-1.5 select-none shrink-0">
      <svg class="w-3.5 h-3.5 text-gold-custom" fill="currentColor" viewBox="0 0 20 20">
        <path d="M5 3a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2V5a2 2 0 00-2-2H5zM5 11a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2v-2a2 2 0 00-2-2H5zM11 5a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V5zM14 11a1 1 0 011 1v1h1a1 1 0 110 2h-1v1a1 1 0 11-2 0v-1h-1a1 1 0 110-2h1v-1a1 1 0 011-1z"></path>
      </svg>
      <span>{{ section.settings.top_banner_text }}</span>
    </div>
  {% endif %}

  <!-- 2. HEADER -->
  <header class="bg-sage-custom/95 py-4 px-6 md:px-12 flex justify-between items-center z-50 shadow-sm border-b border-white/5 select-none sticky top-0 backdrop-blur">
    <div class="flex items-center gap-2">
      {% if section.settings.logo_image %}
        <img src="{{ section.settings.logo_image | image_url: width: 150 }}" alt="Logo" class="h-8 object-contain">
      {% else %}
        <div class="flex items-center gap-1.5">
          <div class="w-6 h-6 bg-gold-custom rounded-full flex items-center justify-center">
            <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 3a9 9 0 109 9c0-.46-.04-.92-.1-1.36a5.38 5.38 0 11-7.54-7.54A9.016 9.016 0 0012 3z"></path></svg>
          </div>
          <span class="text-white text-lg font-bold tracking-tight">SoftNights</span>
        </div>
      {% endif %}
    </div>
    
    <div class="flex items-center gap-4">
      <a href="#sleep-assessment-quiz-section" class="hidden md:inline-block text-xs font-semibold text-white/90 hover:text-white transition-colors">
        Take Assessment
      </a>
      <a href="{{ section.settings.checkout_url | default: '/cart' }}" onclick="softnightsAddToCart(event)" class="bg-gold-custom hover:bg-gold-custom/90 text-white text-xs font-bold py-2.5 px-4 rounded-xl transition-all shadow-md flex items-center gap-1">
        <span>Order Guide</span>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path></svg>
      </a>
    </div>
  </header>

  <!-- 3. HERO SECTION -->
  <section class="max-w-6xl mx-auto py-12 md:py-20 px-6 grid md:grid-cols-2 gap-12 items-center">
    <div class="space-y-6 md:space-y-8 animate-fade-in text-left">
      <!-- Trust Stamp and Star Badges -->
      <div class="flex flex-wrap items-center gap-3">
        <span class="bg-sage-custom/10 text-sage-custom text-[11px] font-bold py-1 px-3 rounded-full uppercase tracking-wider">
          {{ section.settings.trust_badge_text }}
        </span>
        <div class="flex items-center gap-1">
          {% for i in (1..5) %}
            <svg class="w-4 h-4 text-gold-custom" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          {% endfor %}
          <span class="text-xs text-warm-grey-custom font-semibold ml-1">4.9/5 Parental Rating</span>
        </div>
      </div>

      <!-- Main Headline -->
      <h1 class="text-4xl md:text-6xl font-serif font-bold text-charcoal-custom tracking-tight leading-tight">
        {{ section.settings.hero_heading }}
      </h1>

      <!-- Subtitle -->
      <p class="text-base md:text-lg text-warm-grey-custom leading-relaxed">
        {{ section.settings.hero_subheading }}
      </p>

      <!-- Proof points -->
      <ul class="space-y-3.5 text-sm">
        <li class="flex items-center gap-2.5">
          <svg class="w-5 h-5 text-sage-custom" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path>
          </svg>
          <span>100% Gentle, loving adjustments — <strong>absolutely zero raw crying-it-out.</strong></span>
        </li>
        <li class="flex items-center gap-2.5">
          <svg class="w-5 h-5 text-sage-custom" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path>
          </svg>
          <span>Instantly optimized awake-windows to stop bedtime stalling.</span>
        </li>
      </ul>

      <!-- CTA and Countdown Area -->
      <div class="space-y-4">
        <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3">
          <a href="{{ section.settings.checkout_url | default: '/cart' }}" onclick="softnightsAddToCart(event)" class="bg-gold-custom hover:bg-gold-custom/90 text-white font-bold py-4 px-8 rounded-2xl shadow-xl transition-all hover-scale-subtle text-center flex items-center justify-center gap-2 uppercase tracking-wide text-sm">
            <span>Get the Library — {{ section.settings.product_price }}</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
          </a>
          <a href="#sleep-assessment-quiz-section" class="border border-sage-custom/30 hover:bg-sage-custom/5 text-sage-custom font-bold py-4 px-6 rounded-2xl tracking-wide text-sm transition-all text-center">
            Diagnostics Assessment
          </a>
        </div>

        <!-- Real-time countdown timer -->
        <div class="bg-blush-custom/5 border border-blush-custom/20 rounded-xl p-3.5 flex items-center justify-between max-w-md">
          <div class="flex items-center gap-2 text-xs font-semibold text-blush-custom">
            <svg class="w-4 h-4 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            <span>OFFER ENDING SOON</span>
          </div>
          <span id="softnights-hero-timer" class="softnights-font-mono text-xs font-bold text-blush-custom">14m 58s</span>
        </div>
      </div>
    </div>

    <!-- Visual Book Mockups Grid and Trust Sign -->
    <div class="flex flex-col items-center gap-6">
      <div class="relative flex items-center justify-center gap-4 py-8">
        <!-- Main Book Cover Mockup -->
        <div class="relative aspect-[3/4] w-40 sm:w-48 md:w-56 rounded-2xl p-5 flex flex-col justify-between shadow-2xl border border-white/10 transition-transform duration-300 hover:rotate-2 hover:scale-[1.03] select-none text-left bg-sage-custom overflow-hidden text-white">
          <div class="absolute top-0 left-0 bottom-0 w-2.5 bg-gradient-to-r from-white/20 to-transparent"></div>
          <div class="absolute top-0 left-2.5 bottom-0 w-[1px] bg-black/10"></div>
          <div class="space-y-1.5 md:space-y-2">
            <span class="text-[7.5px] md:text-[8px] tracking-widest font-bold text-white/50 uppercase block">CORE PROGRAM BUNDLE</span>
            <h4 class="softnights-font-serif font-bold text-sm md:text-base leading-tight mt-1 text-white">SoftNights Sleep Solutions</h4>
            <div class="w-6 h-[1.5px] bg-gold-custom block rounded"></div>
          </div>
          <p class="text-[9px] md:text-xs text-white/80 leading-relaxed font-sans">The complete guide (from raw evening fights to 15-minute peaceful yawns).</p>
          <span class="text-[7.5px] font-mono font-semibold text-white/50 tracking-wider uppercase block">Softnights Press ©</span>
        </div>

        <!-- Bonus Book Cover Mockup -->
        <div class="relative aspect-[3/4] w-36 sm:w-40 md:w-48 rounded-2xl p-4 flex flex-col justify-between shadow-xl border border-white/10 transition-transform duration-300 hover:-rotate-2 hover:scale-[1.03] select-none text-left bg-gradient-to-br from-gray-800 to-gray-900 overflow-hidden text-white -ml-8 mt-12">
          <div class="absolute top-0 left-0 bottom-0 w-2 bg-gradient-to-r from-white/10 to-transparent"></div>
          <div class="space-y-1.5">
            <span class="text-[7px] tracking-widest font-bold text-gold-custom uppercase block">FREE BUNDLED BONUS</span>
            <h4 class="softnights-font-serif font-bold text-xs md:text-sm leading-tight text-white">The Night Waking Fix</h4>
            <div class="w-4 h-[1.5px] bg-white/20 block rounded"></div>
          </div>
          <p class="text-[8.5px] md:text-[10px] text-white/70 leading-relaxed">Exactly what to do when your child wakes up at 2:00 AM and refuses to resettle.</p>
          <span class="text-[7px] font-mono font-semibold text-white/40 tracking-wider uppercase block">FAST ACTION SHEET</span>
        </div>
      </div>

      <p class="text-[10.5px] text-warm-grey-custom italic">
        ✨ Hover guides to view details. Secure both guides today for only {{ section.settings.product_price }}.
      </p>
    </div>
  </section>

  <!-- 4. PAIN POINTS SECTION -->
  <section class="bg-sage-custom/5 py-16 md:py-20 px-6">
    <div class="max-w-4xl mx-auto space-y-12">
      <div class="text-center space-y-3">
        <span class="text-[11px] font-bold text-sage-custom uppercase tracking-wider">RELATABLE REALITY</span>
        <h2 class="text-3xl md:text-4xl font-bold text-charcoal-custom text-sage-custom font-heading">
          {{ section.settings.pain_heading }}
        </h2>
        <p class="text-sm md:text-base text-warm-grey-custom max-w-xl mx-auto">
          {{ section.settings.pain_subheading }}
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- Exhausting Loop -->
        <div class="bg-white p-6 md:p-8 rounded-3xl border border-blush-custom/20 shadow-sm relative overflow-hidden flex flex-col justify-between">
          <div class="absolute top-0 right-0 w-24 h-24 bg-blush-custom/5 rounded-full blur-xl"></div>
          <div>
            <div class="w-10 h-10 bg-blush-custom/10 text-blush-custom rounded-xl flex items-center justify-center mb-5">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
            </div>
            <h3 class="font-bold text-lg text-charcoal-custom mb-4 font-heading">The Bedtime Battle Loop</h3>
            <ul class="space-y-3.5 text-xs text-warm-grey-custom">
              <li class="flex items-start gap-2.5">
                <span class="text-blush-custom font-bold mt-0.5">✕</span>
                <span><strong>The 2-Hour Stall:</strong> Endless negotiations, demands for cups of water, and 'one more kiss' delays.</span>
              </li>
              <li class="flex items-start gap-2.5">
                <span class="text-blush-custom font-bold mt-0.5">✕</span>
                <span><strong>Hourly Wakings:</strong> Bouncing, rocking, or feeding back to sleep 4+ times a night.</span>
              </li>
              <li class="flex items-start gap-2.5">
                <span class="text-blush-custom font-bold mt-0.5">✕</span>
                <span><strong>Waking Up Defeated:</strong> Starting your days at 5:00 AM completely drained and emotionally raw.</span>
              </li>
            </ul>
          </div>
          <div class="mt-8 pt-4 border-t border-sage-custom/10">
            <span class="italic text-xs text-blush-custom font-sans">“I was sitting on the nursery floor at 3:00 AM sobbing, wondering why my baby wouldn't just close his eyes.”</span>
          </div>
        </div>

        <!-- Soothing Sleep Flow -->
        <div class="bg-white p-6 md:p-8 rounded-3xl border border-sage-custom/20 shadow-sm relative overflow-hidden flex flex-col justify-between">
          <div class="absolute top-0 right-0 w-24 h-24 bg-sage-custom/5 rounded-full blur-xl"></div>
          <div>
            <div class="w-10 h-10 bg-sage-custom/10 text-sage-custom rounded-xl flex items-center justify-center mb-5">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m0-12.728l.707.707m12.728 12.728l.707-.707M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <h3 class="font-bold text-lg text-charcoal-custom mb-4 font-heading">The Soothing Sleep Flow</h3>
            <ul class="space-y-3.5 text-xs text-warm-grey-custom">
              <li class="flex items-start gap-2.5">
                <span class="text-sage-custom font-bold mt-0.5">✓</span>
                <span><strong>Peaceful 15-Min Drifting:</strong> Your child enters their natural sleep window relaxed and ready.</span>
              </li>
              <li class="flex items-start gap-2.5">
                <span class="text-sage-custom font-bold mt-0.5">✓</span>
                <span><strong>Uninterrupted Rest:</strong> Sleeping through multiple transitions with gentle, built-in self-soothing skills.</span>
              </li>
              <li class="flex items-start gap-2.5">
                <span class="text-sage-custom font-bold mt-0.5">✓</span>
                <span><strong>Waking Up Joyful:</strong> Greeted at 7:00 AM by a laughing, alert child who got the rest they need.</span>
              </li>
            </ul>
          </div>
          <div class="mt-8 pt-4 border-t border-sage-custom/10">
            <span class="italic text-xs text-sage-custom font-sans">“We put him down awake, kissed him goodnight, and walked out. Under 10 minutes later he was sleeping peacefully. No tears.”</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. INTERACTIVE 45-SECOND ASSESSMENT (QUIZ) -->
  <section id="sleep-assessment-quiz-section" class="py-16 px-6 relative overflow-hidden">
    <div class="absolute top-1/2 left-0 w-80 h-80 bg-sage-custom/5 rounded-full blur-3xl pointer-events-none -translate-x-1/2 -translate-y-1/2"></div>
    <div class="max-w-4xl mx-auto space-y-10">
      <div class="text-center space-y-3">
        <span class="text-[11px] font-bold text-gold-custom uppercase tracking-wider">PERSONALIZED PERSPECTIVE</span>
        <h2 class="text-3xl md:text-4xl font-bold text-charcoal-custom">Sleep Pattern Diagnostician</h2>
        <p class="text-sm md:text-base text-warm-grey-custom max-w-xl mx-auto">
          Is it a developmental leap? A sleep association? Or cortisol window delay? Take our custom 45-second assessment to instantly understand their nightly patterns.
        </p>
      </div>

      <div class="bg-white rounded-3xl p-6 md:p-10 shadow-xl border border-sage-custom/10 max-w-2xl mx-auto ring-1 ring-sage-custom/5">
        
        <!-- Quiz Window: Question State -->
        <div id="softnights-quiz-question-box" class="space-y-8">
          <div class="flex items-center justify-between border-b border-sage-custom/10 pb-4">
            <span id="softnights-quiz-progress-text" class="text-xs font-semibold text-sage-custom uppercase tracking-wider">Step 1 of 3</span>
            <div class="w-24 bg-sage-custom/15 h-1.5 rounded-full overflow-hidden">
              <div id="softnights-quiz-progress-bar" class="bg-sage-custom h-full transition-all duration-300" style="width: 33%"></div>
            </div>
          </div>

          <h3 id="softnights-quiz-headline" class="text-xl md:text-2xl font-bold text-charcoal-custom font-heading leading-snug">
            How old is your sweet little one?
          </h3>

          <div id="softnights-quiz-options-container" class="grid gap-3">
            <!-- Dynamically populated via Javascript -->
          </div>
        </div>

        <!-- Quiz Window: Result State (Hidden by default) -->
        <div id="softnights-quiz-result-box" class="hidden space-y-8 animate-fade-in">
          <div class="bg-sage-custom/5 border border-sage-custom/15 rounded-3xl p-6 md:p-8 space-y-6 text-left relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-sage-custom/5 rounded-full blur-2xl"></div>
            
            <div class="flex items-center gap-2 text-sage-custom">
              <svg class="w-5 h-5 text-gold-custom" fill="currentColor" viewBox="0 0 20 20"><path d="M5 3a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2V5a2 2 0 00-2-2H5zM5 11a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2v-2a2 2 0 00-2-2H5zM11 5a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V5zM14 11a1 1 0 011 1v1h1a1 1 0 110 2h-1v1a1 1 0 11-2 0v-1h-1a1 1 0 110-2h1v-1a1 1 0 011-1z"></path></svg>
              <span class="text-xs font-bold tracking-wider uppercase">Personalized Diagnostic Completed</span>
            </div>

            <div class="space-y-2">
              <span id="softnights-quiz-result-syndrome" class="text-xs font-mono font-bold text-blush-custom uppercase block tracking-wider">The Fragmented Sleep Association Cycle</span>
              <h4 id="softnights-quiz-result-title" class="text-2xl font-bold text-charcoal-custom font-heading leading-tight">Fragile sleep transition spikes</h4>
            </div>

            <p id="softnights-quiz-result-desc" class="text-sm text-warm-grey-custom leading-relaxed">
              Your child has linked falling asleep with external triggers (like feeding or rocking). Whenever they complete a light sleep cycle (every 45 minutes), they arouse slightly and call out for that exact system to be repeated.
            </p>

            <div class="bg-white/80 p-5 rounded-2xl border border-sage-custom/10 text-xs text-warm-grey-custom leading-relaxed relative z-10 flex gap-3.5 items-start">
              <div class="w-8 h-8 rounded-full bg-gold-custom/10 text-gold-custom flex items-center justify-center shrink-0">💡</div>
              <div>
                <strong class="font-bold text-charcoal-custom block mb-0.5">Tailored Guide Recommendation:</strong>
                <span id="softnights-quiz-result-rec">Our 'Gentle Lay-Down Setup' teaches how to slow separate the sleep association from feeding without traumatic crying.</span>
              </div>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row items-center gap-3.5 pt-2">
            <a href="{{ section.settings.checkout_url | default: '/cart' }}" onclick="softnightsAddToCart(event)" class="w-full sm:flex-1 bg-gold-custom hover:bg-gold-custom/90 text-white font-bold py-4 px-8 rounded-2xl shadow-xl transition-all hover-scale-subtle text-center flex items-center justify-center gap-2 uppercase tracking-wide text-sm">
              <span>Grab Library & Solutions</span>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </a>
            <button onclick="resetSoftnightsQuiz()" class="text-xs font-semibold text-warm-grey-custom hover:text-charcoal-custom transition-colors flex items-center gap-1.5 py-3">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 12H19M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              <span>Restart Diagnostic</span>
            </button>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- 6. WHAT IS INCLUDED SECTION -->
  <section class="bg-cream-custom py-16 md:py-20 px-6 border-t border-b border-sage-custom/10">
    <div class="max-w-4xl mx-auto space-y-12">
      <div class="text-center space-y-3">
        <span class="text-[11px] font-bold text-gold-custom uppercase tracking-wider">THE ANATOMY OF SLEEP</span>
        <h2 class="text-3xl md:text-4xl font-bold text-charcoal-custom font-heading">The Softnights Sleep Library</h2>
