<script>
  // 1. Interactive assessment Quiz Logic
  var softnightsQuizQuestions = [
    {
      id: "age",
      question: "How old is your sweet little one?",
      options: [
        { label: "Newborn (0 - 3 Months)", value: "newborn", description: "Navigating day/night confusion and initial patterns" },
        { label: "Infant (4 - 11 Months)", value: "infant", description: "Dealing with the infamous sleep regressions" },
        { label: "Toddler (1 - 2 Years)", value: "toddler", description: "Bedtime protests, active minds, and standing in the crib" },
        { label: "Preschooler (3+ Years)", value: "preschool", description: "Stalling, requesting 'one more glass of water', and fears" }
      ]
    },
    {
      id: "biggest_challenge",
      question: "What is your biggest bedtime battle point?",
      options: [
        { label: "Vicious Bedtime Stall", value: "stalling", description: "Taking 2+ hours with endless negotiations and bedtime protests" },
        { label: "Frequent Night Waking", value: "waking", description: "Waking up 3, 4, or 5+ times and requiring rocking or nursing to resettle" },
        { label: "Extremely Short Naps", value: "naps", description: "Struggling to nap longer than 30 minutes, keeping them cranky" },
        { label: "Impossible Early Waking", value: "early", description: "Waking up for the day at 4:30 AM or 5:00 AM, exhausted" }
      ]
    },
    {
      id: "settling_method",
      question: "How does your child currently fall asleep?",
      options: [
        { label: "Nursing, feeding, or eating to sleep", value: "feed", description: "Requires milk to drift off every single time" },
        { label: "Physical motion: Rocking, bouncing, or patting", value: "rock", description: "Loves physical movement to trigger deep drowsiness" },
        { label: "Co-sleeping or lying right next to you", value: "cosleep", description: "Cannot stay in their own mattress without a parent present" },
        { label: "Independently, but takes a highly variable time", value: "independent", description: "Capable of self-soothing but struggles in certain shifts" }
      ]
    }
  ];

  var softnightsQuizState = {
    currentIdx: 0,
    answers: {}
  };

  function renderSoftnightsQuizQuestion() {
    var questionEl = document.getElementById("softnights-quiz-headline");
    var containerEl = document.getElementById("softnights-quiz-options-container");
    var progressText = document.getElementById("softnights-quiz-progress-text");
    var progressBar = document.getElementById("softnights-quiz-progress-bar");
    
    if (!questionEl || !containerEl) return;
    
    var currentQ = softnightsQuizQuestions[softnightsQuizState.currentIdx];
    questionEl.innerText = currentQ.question;
    progressText.innerText = "Step " + (softnightsQuizState.currentIdx + 1) + " of 3";
    progressBar.style.width = ((softnightsQuizState.currentIdx + 1) / 3 * 100) + "%";

    containerEl.innerHTML = "";
    currentQ.options.forEach(function(opt) {
      var btn = document.createElement("button");
      btn.className = "w-full text-left p-4.5 rounded-2xl bg-cream-custom/20 hover:bg-sage-custom/10 border border-sage-custom/10 hover:border-sage-custom/25 transition-all outline-none focus:outline-none flex flex-col gap-0.5 cursor-pointer text-charcoal-custom";
      btn.onclick = function() {
        selectSoftnightsAnswer(currentQ.id, opt.value);
      };

      var labelSpan = document.createElement("span");
      labelSpan.className = "text-xs sm:text-sm font-bold block";
      labelSpan.innerText = opt.label;

      var descSpan = document.createElement("span");
      descSpan.className = "text-[10px] text-warm-grey-custom font-normal leading-normal";
      descSpan.innerText = opt.description;

      btn.appendChild(labelSpan);
      btn.appendChild(descSpan);
      containerEl.appendChild(btn);
    });
  }

  function selectSoftnightsAnswer(questionId, value) {
    softnightsQuizState.answers[questionId] = value;
    if (softnightsQuizState.currentIdx < softnightsQuizQuestions.length - 1) {
      softnightsQuizState.currentIdx++;
      renderSoftnightsQuizQuestion();
    } else {
      showSoftnightsQuizResult();
    }
  }

  function showSoftnightsQuizResult() {
    var questionBox = document.getElementById("softnights-quiz-question-box");
    var resultBox = document.getElementById("softnights-quiz-result-box");
    if (!questionBox || !resultBox) return;

    var challenge = softnightsQuizState.answers["biggest_challenge"];
    var age = softnightsQuizState.answers["age"];

    var resultTitle = "The Fragmented Sleep Association Cycle";
    var resultSyndrome = "Fragile sleep transition spikes";
    var resultDesc = "Your child has linked falling asleep with external triggers (like feeding or rocking). Whenever they complete a light sleep cycle (every 45 minutes), they arouse slightly and call out for that exact system to be repeated.";
    var resultRec = "Our 'Gentle Lay-Down Setup' in Section 3 of the Sleep Solutions Guide specifically teaches how to slowly separate the sleep association from feeding without traumatic crying.";

    if (challenge === "stalling") {
      resultTitle = "The Overtired Sleep Window Mismatch";
      resultSyndrome = "Melatonin-cortisol battlefront";
      resultDesc = "The '2-hour bedtime struggle' is actually a physiological response: if kids miss their biological sleep window, their brains produce a surge of cortisol (stress hormone) and adrenaline, giving them a 'second wind' that mimics energetic resistance.";
      resultRec = "By shifting the bedtime by just 15 minutes and using the 4-step 'Silent Transition' visual routing helper (featured in our routine builder), bedtime is cut down to under 20 minutes.";
    } else if (age === "toddler" || age === "preschool") {
      resultTitle = "The Boundary Exploration Paradox";
      resultSyndrome = "Toddler independence testing";
      resultDesc = "Toddlers require strict cognitive predictability to feel secure enough to let go of waking life. Protests and requests are their way of checking if boundaries are rigid. Liquid or floating schedules breed bedtime anxiety.";
      resultRec = "Building a highly visual bedtime timeline (and using the Toddler Bedtime Agreement on Page 42) stops stalling in its tracks.";
    } else if (challenge === "naps" || challenge === "early") {
      resultTitle = "The Overtired Daylight Deficit";
      resultSyndrome = "Disrupted circadian balance";
      resultDesc = "Short daytime naps are draining their calming sleep pressure, leading to an over-stimulated state by evening. Bedtime becomes a struggle because their nervous system is in hyper-drive.";
      resultRec = "The Sleep Solutions Guide introduces the 'Flexible Sleep Horizon System' which naturally extends naps, allowing your infant to sleep peacefully through the night.";
    }

    document.getElementById("softnights-quiz-result-title").innerText = resultTitle;
    document.getElementById("softnights-quiz-result-syndrome").innerText = resultSyndrome;
    document.getElementById("softnights-quiz-result-desc").innerText = resultDesc;
    document.getElementById("softnights-quiz-result-rec").innerText = resultRec;

    questionBox.classList.add("hidden");
    resultBox.classList.remove("hidden");
  }

  function resetSoftnightsQuiz() {
    softnightsQuizState.currentIdx = 0;
    softnightsQuizState.answers = {};
    document.getElementById("softnights-quiz-question-box").classList.remove("hidden");
    document.getElementById("softnights-quiz-result-box").classList.add("hidden");
    renderSoftnightsQuizQuestion();
  }

  // 2. Countdown Timer
  function initSoftnightsTimer() {
    var element = document.getElementById("softnights-hero-timer");
    if (!element) return;
    
    var savedTime = sessionStorage.getItem("softnights_countdown_shopify");
    var timeLeft = savedTime ? parseInt(savedTime, 10) : 14 * 60 + 58;

    var timer = setInterval(function() {
      if (timeLeft <= 0) {
        timeLeft = 14 * 60 + 58;
      } else {
        timeLeft--;
      }
      sessionStorage.setItem("softnights_countdown_shopify", timeLeft);
      
      var mins = Math.floor(timeLeft / 60);
      var secs = timeLeft % 60;
      var timeStr = mins + "m " + (secs < 10 ? "0" : "") + secs + "s";
      element.innerText = timeStr;
    }, 1000);
  }

  // 3. Toggle FAQ Accordion
  function toggleSoftnightsFaq(button) {
    var content = button.nextElementSibling;
    var icon = button.querySelector("svg");
    
    // Close other FAQs
    var allFaqs = button.parentElement.parentElement.children;
    for (var i = 0; i < allFaqs.length; i++) {
       var otherBtn = allFaqs[i].firstElementChild;
       var otherContent = otherBtn.nextElementSibling;
       var otherIcon = otherBtn.querySelector("svg");
       if (otherBtn !== button) {
         otherContent.style.maxHeight = null;
         otherIcon.classList.remove("rotate-180");
       }
    }

    if (content.style.maxHeight) {
      content.style.maxHeight = null;
      icon.classList.remove("rotate-180");
    } else {
      content.style.maxHeight = content.scrollHeight + "px";
      icon.classList.add("rotate-180");
    }
  }

  // 4. Cart / Add to Cart Action
  function softnightsAddToCart(event) {
    var variantId = "{{ section.settings.product_variant_id }}";
    if (variantId && variantId !== "") {
      event.preventDefault();
      // Redirect to Shopify checkout or AJAX add-to-cart
      window.location.href = "/cart/add?id=" + variantId + "&quantity=1" + "&return_to=/checkout";
    }
  }

  // Hook everything on window load or DOM loaded
  document.addEventListener("DOMContentLoaded", function() {
    renderSoftnightsQuizQuestion();
    initSoftnightsTimer();
  });
</script>

