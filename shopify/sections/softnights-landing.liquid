{% comment %}
  SoftNights Sleep Solutions — Complete High-Converting Shopify Liquid Section
  Custom built to be 100% compatible with modern Shopify Dawn theme & Vintage Shopify themes.
  Includes a styled layout, custom color pickers, an interactive sleep quiz, custom testimonial blocks, and FAQs.
  
  HOW TO USE:
  1. In your Shopify Theme editor, go to Edit Code -> Sections -> Add a new section called "softnights-landing".
  2. Paste this entire content.
  3. In customize visual theme, add the section to your landing page and configure your settings and products.
{% endcomment %}

<!-- SoftNights custom styling scoped strictly to this section -->
<style>
  #shopify-section-{{ section.id }} .softnights-wrapper {
    --color-cream: {{ section.settings.color_cream | default: '#FAF7F2' }};
    --color-sage: {{ section.settings.color_sage | default: '#5A6E63' }};
    --color-sage-light: {{ section.settings.color_sage_light | default: '#FAF7F2' }};
    --color-charcoal: {{ section.settings.color_charcoal | default: '#2D3430' }};
    --color-gold: {{ section.settings.color_gold | default: '#D99E6C' }};
    --color-blush: {{ section.settings.color_blush | default: '#BA6B57' }};
    --color-warm-grey: {{ section.settings.color_warm_grey | default: '#606D66' }};

    background-color: var(--color-cream);
    color: var(--color-charcoal);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    line-height: 1.5;
    font-size: 14px;
    -webkit-font-smoothing: antialiased;
    padding: 0;
    margin: 0;
  }

  /* Structural Containers */
  #shopify-section-{{ section.id }} .sn-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 20px;
    box-sizing: border-box;
  }

  /* Typography */
  #shopify-section-{{ section.id }} .sn-font-heading {
    font-family: Georgia, serif;
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-charcoal);
  }

  #shopify-section-{{ section.id }} .sn-font-mono {
    font-family: Menlo, Monaco, Consolas, "Liberation Mono", Courier, monospace;
  }

  /* Utility Styles */
  #shopify-section-{{ section.id }} .text-xs { font-size: 12px; }
  #shopify-section-{{ section.id }} .text-sm { font-size: 13px; }
  #shopify-section-{{ section.id }} .text-base { font-size: 15px; }
  #shopify-section-{{ section.id }} .text-lg { font-size: 18px; }
  #shopify-section-{{ section.id }} .font-semibold { font-weight: 600; }
  #shopify-section-{{ section.id }} .font-bold { font-weight: 700; }
  #shopify-section-{{ section.id }} .uppercase { text-transform: uppercase; }
  #shopify-section-{{ section.id }} .tracking-wider { letter-spacing: 0.05em; }
  #shopify-section-{{ section.id }} .tracking-widest { letter-spacing: 0.12em; }
  
  #shopify-section-{{ section.id }} .btn-primary {
    background-color: var(--color-gold);
    color: #ffffff !important;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 14px 28px;
    border-radius: 12px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: transform 0.2s, background-color 0.2s;
    box-shadow: 0 10px 20px rgba(217, 158, 108, 0.15);
  }

  #shopify-section-{{ section.id }} .btn-primary:hover {
    background-color: #cb8f5d;
    transform: translateY(-1px);
  }

  #shopify-section-{{ section.id }} .btn-secondary {
    background-color: transparent;
    color: var(--color-sage) !important;
    font-weight: 700;
    padding: 13px 26px;
    border-radius: 12px;
    border: 1.5px solid var(--color-sage);
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.2s, color 0.2s;
  }

  #shopify-section-{{ section.id }} .btn-secondary:hover {
    background-color: rgba(90, 110, 99, 0.05);
  }

  #shopify-section-{{ section.id }} .announcement-banner {
    background-color: var(--color-sage);
    color: #ffffff;
    font-size: 11px;
    font-weight: 600;
    text-align: center;
    padding: 8px 16px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* Header styles */
  #shopify-section-{{ section.id }} .softnights-header {
    background-color: rgba(250, 247, 242, 0.96);
    border-bottom: 1px solid rgba(90, 110, 99, 0.1);
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 14px 0;
    backdrop-filter: blur(8px);
  }

  #shopify-section-{{ section.id }} .header-flex {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .logo-text {
