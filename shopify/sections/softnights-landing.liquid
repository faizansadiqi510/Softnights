<script>
  // Dynamic Selector variables strictly aligned to section ID namespaces
  (function() {
    var sectId = "{{ section.id }}";
    var container = document.getElementById("shopify-section-" + sectId);
    if (!container) return;

    // Countdown clock state
    var countdownEl = container.querySelector("#counter-clock-" + sectId);
    if (countdownEl) {
      var storeKey = "softnights_countdown_sect_" + sectId;
      var savedTime = sessionStorage.getItem(storeKey);
      var timeLeft = savedTime ? parseInt(savedTime, 10) : 14 * 60 + 58;

      var timerId = setInterval(function() {
        if (timeLeft <= 0) {
          timeLeft = 14 * 60 + 58;
        } else {
          timeLeft--;
        }
        sessionStorage.setItem(storeKey, timeLeft);

        var mins = Math.floor(timeLeft / 60);
        var secs = timeLeft % 60;
        countdownEl.innerText = mins + "m " + (secs < 10 ? "0" : "") + secs + "s";
      }, 1000);
    }

    // Interactive sleep pattern assessment data
    var questionsList = [
      {
        id: "age",
        question: "How old is your sweet little one?",
        options: [
          { label: "Newborn (0 - 3 Months)", val: "newborn", desc: "Navigating day/night biological rhythms" },
          { label: "Infant (4 - 11 Months)", val: "infant", desc: "Isolating sleep regression milestone blocks" },
          { label: "Toddler (1 - 2 Years)", val: "toddler", desc: "Active crib protests and setting bedtime boundaries" }
        ]
      },
      {
        id: "challenge",
        question: "What is your biggest bedtime struggle point?",
        options: [
          { label: "Endless Stalling Battle", val: "stalling", desc: "Takes over 2 hours with constant kisses or water demands" },
          { label: "Hourly Midnight Wakings", val: "waking", desc: "Waking frequently needing rocking or milk to fall back" },
          { label: "Unpredictable 5:00 AM Wakings", val: "early", desc: "Waking up extremely early of the day completely drained" }
        ]
      }
    ];

    var quizState = {
      curIdx: 0,
      answers: {}
    };

    var outputBox = container.querySelector("#quiz-result-box-" + sectId);
    var questionBox = container.querySelector("#quiz-question-box-" + sectId);
    var progressInner = container.querySelector("#quiz-progress-inner-{{ section.id }}");
    var stepIndicator = container.querySelector("#quiz-step-indicator-{{ section.id }}");
    var qHeading = container.querySelector("#quiz-question-text-{{ section.id }}");
    var optionsContainer = container.querySelector("#quiz-options-container-{{ section.id }}");

    // Diagnostic recommendations lookups
    var lookupDiagnostics = {
      "stalling": {
        title: "The Overtired Sleep Window Mismatch",
        desc: " Bedtime battles are usually physiological: when children remain awake past their natural circadian window, their bodies trigger cortisol (alertness stress hormone) and adrenaline. This second wind makes bedtime negotiations last for hours.",
        reco: "Shifting their evening routine forward by just 15 minutes and using the 'Silent Transition timeline' on Page 24 cuts bedtime down from 2 hours to 20 minutes effortlessly."
      },
      "waking": {
        title: "The Fragmented Sleep Association Cycle",
        desc: "Your child has linked drifting asleep with external assistance (like pacifiers, rocking, or feeding). Because sleep cycles complete every 45-90 minutes, they arouse slightly and call out for that same trigger to re-enter sleep.",
        reco: "Our responsive 'Gentle Lay-Down System' in Section 3 of the Sleep Solutions Guide teaches you how to dissolve sleep associations safely and lovingly without crying."
      },
      "early": {
        title: "Daylight Circadian Deficit",
        desc: "Early morning awakenings at 5:00 AM are caused by an accumulation of overtiredness during the previous afternoon, leading to a spike in morning cortisol production.",
        reco: "Using Section 2's 'Flexible Sleep Horizon Schedule' stabilizes afternoon nap wake times, naturally expanding night sleeping until 7:00 AM."
      }
    };

    function renderActiveQuestion() {
      if (quizState.curIdx >= questionsList.length) {
        showQuizResults();
        return;
      }

      var currentQ = questionsList[quizState.curIdx];
      
      // Update UI texts
      if (qHeading) qHeading.innerText = currentQ.question;
      if (stepIndicator) stepIndicator.innerText = "Step " + (quizState.curIdx + 1) + " of " + questionsList.length;
      if (progressInner) progressInner.style.width = ((quizState.curIdx + 1) / questionsList.length * 100) + "%";

      if (optionsContainer) {
        optionsContainer.innerHTML = "";
        currentQ.options.forEach(function(opt) {
          var btn = document.createElement("button");
          btn.className = "quiz-option";
          btn.type = "button";
          btn.onclick = function() {
            quizState.answers[currentQ.id] = opt.val;
            quizState.curIdx++;
            renderActiveQuestion();
          };

          var label = document.createElement("span");
          label.className = "quiz-option-label";
          label.innerText = opt.label;

          var desc = document.createElement("span");
          desc.className = "quiz-option-desc";
          desc.innerText = opt.desc;

          btn.appendChild(label);
          btn.appendChild(desc);
          optionsContainer.appendChild(btn);
        });
      }
    }

    function showQuizResults() {
      if (questionBox) questionBox.style.display = "none";
      if (outputBox) outputBox.style.display = "block";

      var answerChallenge = quizState.answers["challenge"] || "stalling";
      var report = lookupDiagnostics[answerChallenge] || lookupDiagnostics["stalling"];

      var reportTitleEl = container.querySelector("#quiz-res-title-" + sectId);
      var reportDescEl = container.querySelector("#quiz-res-desc-" + sectId);
      var reportRecoEl = container.querySelector("#quiz-res-reco-" + sectId);

      if (reportTitleEl) reportTitleEl.innerText = report.title;
      if (reportDescEl) reportDescEl.innerText = report.desc;
      if (reportRecoEl) reportRecoEl.innerText = report.reco;
    }

    var quizResetBtn = container.querySelector("#btn-reset-quiz-" + sectId);
    if (quizResetBtn) {
      quizResetBtn.onclick = function() {
        quizState.curIdx = 0;
        quizState.answers = {};
        if (questionBox) questionBox.style.display = "block";
        if (outputBox) outputBox.style.display = "none";
        renderActiveQuestion();
      };
    }

    // Initialize Quiz
    renderActiveQuestion();
  })();

  // Accordion FAQ toggle scoped to element instances
  function toggleShopifyFaqElement(button) {
    var item = button.parentElement;
    var content = button.nextElementSibling;
    
    var wasActive = item.classList.contains("active");
    
    // Close sibling accordion items
    var siblings = item.parentElement.querySelectorAll(".faq-item");
    siblings.forEach(function(sib) {
      sib.classList.remove("active");
      var sibContent = sib.querySelector(".faq-content");
      if (sibContent) sibContent.style.maxHeight = null;
    });

    if (!wasActive) {
      item.classList.add("active");
      content.style.maxHeight = content.scrollHeight + "px";
    } else {
      item.classList.remove("active");
      content.style.maxHeight = null;
    }
  }
</script>

