    display: flex;
    flex-direction: column;
    justify-content: space-between;
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .book-label {
    font-size: 8px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 700;
    opacity: 0.8;
  }

  #shopify-section-{{ section.id }} .book-title {
    font-size: 15px;
    font-weight: bold;
    margin-top: 8px;
