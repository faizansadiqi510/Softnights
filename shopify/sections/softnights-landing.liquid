    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
  }

  #shopify-section-{{ section.id }} .card-icon-box-blush {
    background-color: rgba(186, 107, 87, 0.1);
    color: var(--color-blush);
  }

  #shopify-section-{{ section.id }} .card-icon-box-sage {
    background-color: rgba(90, 110, 99, 0.1);
    color: var(--color-sage);
  }

  #shopify-section-{{ section.id }} .card-title {
    font-size: 18px;
    margin: 0 0 16px 0;
  }

  #shopify-section-{{ section.id }} .card-bullets {
    padding-left: 0;
    list-style: none;
    margin: 0 0 30px 0;
  }

  #shopify-section-{{ section.id }} .card-bullet-item {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-size: 13px;
    margin-bottom: 12px;
    line-height: 1.4;
