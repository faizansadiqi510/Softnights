    font-size: 14px;
    margin: 0;
    line-height: 1.5;
  }

  #shopify-section-{{ section.id }} .comparison-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
  }

  #shopify-section-{{ section.id }} .comparison-card {
