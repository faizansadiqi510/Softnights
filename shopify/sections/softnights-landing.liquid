    align-items: center;
    gap: 6px;
  }

  #shopify-section-{{ section.id }} .logo-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-gold);
    display: inline-block;
  }

  /* Hero Elements */
  #shopify-section-{{ section.id }} .hero-section {
    padding: 50px 0 80px 0;
  }

  #shopify-section-{{ section.id }} .hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 50px;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .hero-tag {
    background-color: rgba(90, 110, 99, 0.08);
    color: var(--color-sage);
    font-size: 11px;
    font-weight: 700;
    padding: 4px 12px;
