    font-weight: bold;
  }

  #shopify-section-{{ section.id }} .card-quote {
    border-t: 1px solid rgba(90, 110, 99, 0.08);
    padding-top: 16px;
    font-style: italic;
    font-size: 13px;
    color: var(--color-sage);
  }

  /* Diagnostic quiz assessment */
  #shopify-section-{{ section.id }} .quiz-section {
    padding: 80px 0;
    position: relative;
  }

  #shopify-section-{{ section.id }} .quiz-box {
    background-color: #ffffff;
