    opacity: 0.6;
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  /* Relatable Realities - Pain section */
  #shopify-section-{{ section.id }} .reality-section {
    background-color: rgba(90, 110, 99, 0.03);
    padding: 80px 0;
    border-top: 1px solid rgba(90, 110, 99, 0.05);
    border-bottom: 1px solid rgba(90, 110, 99, 0.05);
  }

  #shopify-section-{{ section.id }} .section-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 50px auto;
  }

  #shopify-section-{{ section.id }} .section-subtitle {
    font-size: 11px;
    font-weight: 700;
    color: var(--color-sage);
    text-transform: uppercase;
